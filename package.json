{
  "name": "ai-stock-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "可配置主题的股票研究看板（长桥/东方财富/新浪/腾讯 + OpenAI 兼容模型）",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@vueuse/core": "^12.4.0",
    "echarts": "^5.6.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.0.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "mongodb": "^6.21.0",
    "protobufjs": "^7.5.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.0",
    "ws": "^8.18.3"
  }
}
