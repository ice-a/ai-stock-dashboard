# Site access password. If empty, password protection is disabled.
SITE_PASSWORD=
# Optional cookie signing secret. Defaults to SITE_PASSWORD when omitted.
SITE_AUTH_SECRET=
# Optional login max age in seconds. Defaults to 604800.
SITE_AUTH_MAX_AGE_SECONDS=604800

# LongPort market data credentials.
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
# Optional region. Use cn for China-region LongPort credentials, hk/global otherwise.
LONGPORT_REGION=
# Optional overrides. Defaults depend on LONGPORT_REGION.
LONGPORT_HTTP_URL=
LONGPORT_QUOTE_WS_URL=

# Server-managed OpenAI-compatible AI config.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Optional app defaults.
APP_LIST_REFRESH_SECONDS=60
APP_DETAIL_REFRESH_SECONDS=15
