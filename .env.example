# Optional site access password. Leave empty to disable password protection.
SITE_PASSWORD=

# Default AI configuration (users can override in settings)
# These values are used as defaults when users haven't configured their own
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# User API call limit (per user, per session)
# Users can call AI this many times before needing to reset
USER_API_CALL_LIMIT=100

# MongoDB connection string (optional)
# Format: mongodb://username:password@host:port/database
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=

# MongoDB database name (optional, default: ai_stock_dashboard)
MONGODB_DB_NAME=ai_stock_dashboard

# Longbridge API configuration (optional)
# Users can also configure their own credentials in the user settings
# Using Longbridge China region API (recommended for China users)
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
LONGBRIDGE_REGION=cn

# Refresh intervals (optional)
APP_LIST_REFRESH_SECONDS=60
APP_DETAIL_REFRESH_SECONDS=15
